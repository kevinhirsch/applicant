%% Applicant — moderncv (banking) resume template (FR-RESUME-3, FR-FONT-2).
%% Adapted from kevinhirsch/ai-job-search cv/main_example.tex (see ../README.md).
%% Compile with lualatex (pdflatex fails on fontawesome5 font-expansion errors);
%% xelatex where fontspec is strictly required (CLAUDE.md gotchas).
%%
%% This is a Jinja2 template rendered with LaTeX-safe delimiters so it does not
%% collide with TeX braces (angle-bracket variable/statement/comment markers, see
%% moderncv_converter.py). The LaTeX adapter renders it with a context built from a
%% parsed base resume's structured, TRUTHFUL content (FR-RESUME-2): the engine
%% reframes/reorders real experience but never injects a field that has no source.
%% All values are LaTeX-escaped and em-dash-stripped before they land here.
\documentclass[11pt,a4paper,sans]{moderncv}
\moderncvstyle{banking}
\moderncvcolor{blue}

%% Large name styling, tolerant of the moderncv version on the host: modern
%% moderncv (>= v2.x, the version texlive-latex-extra ships) renders the whole
%% name through \namestyle, while older releases styled \firstnamestyle and
%% \lastnamestyle separately. \providecommand defines each hook only when the
%% installed moderncv lacks it (so the following \renewcommand can never fail with
%% "undefined command"), then we apply the same large style to all three so the
%% name renders identically whichever command moderncv actually uses.
\providecommand*{\namestyle}[1]{#1}
\providecommand*{\firstnamestyle}[1]{#1}
\providecommand*{\lastnamestyle}[1]{#1}
\renewcommand*{\namestyle}[1]{{\fontsize{34}{36}\bfseries\upshape\color{color1}#1}}
\renewcommand*{\firstnamestyle}[1]{{\fontsize{34}{36}\bfseries\upshape\color{color1}#1}}
\renewcommand*{\lastnamestyle}[1]{{\fontsize{34}{36}\bfseries\upshape\color{color1}#1}}
\renewcommand*{\sectionstyle}[1]{{\sectionfont\color{color1}#1}}

%% inputenc is a pdflatex-era package; under the Unicode engines this renderer uses
%% (xelatex/lualatex) input is already UTF-8 and loading inputenc is at best a no-op
%% and can clash. Load it ONLY on a legacy 8-bit engine so the source compiles on any
%% engine the host happens to provide. ``iftex`` (the modern, non-deprecated probe;
%% ships in texlive-latex-base) exposes \ifPDFTeX without loading the obsolete
%% ifxetex/ifluatex shims.
\usepackage{iftex}
\ifPDFTeX
  \usepackage[utf8]{inputenc}
\fi
%% NB: do not \usepackage{hyperref} here — moderncv loads it itself as
%% \RequirePackage[unicode]{hyperref} at the end of the preamble, so an explicit
%% optionless load raises "Option clash for package hyperref" and aborts the
%% compile. Its macros (\href etc.) remain available from moderncv's own load.
\usepackage[scale=0.80]{geometry}
\usepackage{needspace}  %% guard against orphaned entry titles (fidelity check)

% personal data
\name{<< first_name >>}{<< last_name >>}
<% if address %>\address{<< address >>}{}{}
<% endif -%>
<% if phone %>\phone[mobile]{<< phone >>}
<% endif -%>
<% if email %>\email{<< email >>}
<% endif -%>
<% if extra_info %>\extrainfo{<< extra_info >>}
<% endif %>
\begin{document}
\makecvtitle

<% if profile_statement %>
\vspace{6pt}
\small{<< profile_statement >>}
<% endif %>
<% if competencies %>
\section{Core Competencies}
\begin{itemize}
<% for item in competencies %>\item \textbf{<< item.category >>}: << item.detail >>
<% endfor %>\end{itemize}
<% endif %>
<% if experience %>
\section{Professional Experience}
<% for role in experience %>\needspace{4\baselineskip}
\cventry{<< role.dates >>}{<< role.title >>}{<< role.company >>}{<< role.location >>}{}{<% if role.bullets %>
\begin{itemize}
<% for bullet in role.bullets %>\item << bullet >>
<% endfor %>\end{itemize}
<% endif %>}
\vspace{3pt}
<% endfor %>
<% endif %>
<% if education %>
\section{Education}
<% for edu in education %>\needspace{3\baselineskip}
\cventry{<< edu.dates >>}{<< edu.degree >>}{<< edu.institution >>}{<< edu.location >>}{}{<< edu.detail >>}
\vspace{3pt}
<% endfor %>
<% endif %>
<% if skills %>
\section{Skills}
\cvitem{}{<< skills_line >>}
<% endif %>
\end{document}
