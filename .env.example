# Applicant — environment template. Copy to .env and edit. Secrets never committed.

# --- Deployment mode (FR-DEPLOY) ---------------------------------------------
# "" (default) = every integration ships hermetic/safe (no network, no live browser,
# no scheduler). "production" = ONE preset that turns on live browser, live discovery,
# live notifications, durable orchestration (DBOS), and the 24/7 scheduler at once --
# the engine does real work out of the box. You can still override any individual flag.
APPLICANT_MODE=

# --- Storage (FR-CRIT-4, FR-DUR-3: DBOS state co-resides in this same Postgres) ---
DATABASE_URL=postgresql+psycopg://applicant:applicant@localhost:5432/applicant

# --- Static / frontend (FR-UI-1: vendored Applicant + our screens served from FastAPI) ---
APP_STATIC_DIR=frontend/static

# --- LLM (FR-LLM-1/2: OpenAI-compatible cloud OR local/network Ollama; runs fully local) ---
# Until LLM_* is configured the OOBE LLM gate blocks downstream routes (FR-UI-5, FR-OOBE-1).
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Per-provider LLM request cap (req/min). 0 disables; the conservative default 30
# keeps runaway token spend in check. Raise it only when you know your provider's
# rate-card and your agent tick cadence. Paired with LLM_RATE_PERIOD (seconds, default 60).
LLM_RATE_LIMIT=30
LLM_RATE_PERIOD=60.0

# --- Credential vault master key file (FR-VAULT-3: strict-permission key-file on disk) ---
CREDENTIAL_KEYFILE=secrets/master.key

# --- Durable orchestration (FR-DUR-3). "shim" = DB/file checkpoint (default, no PG needed); "dbos" = DBOS Transact ---
ORCHESTRATOR_BACKEND=shim
CHECKPOINT_DIR=.applicant_checkpoints

# --- Scheduler (FR-DIG-1, FR-NOTIF-2, NFR-247-1). OFF by default so tests/TestClient
# never spin a live loop; set true in a real deployment to run the 24/7 cadence. ---
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=60

# --- Browser engine (FR-STEALTH-1, FR-PREFILL-1) ---
# The browser the agent drives for ALL outbound automation traffic.
# camoufox (default) = a Firefox-based anti-detect browser with its own coherent
# fingerprint + IP-coherent geolocation (GeoIP). chromium = the patchright + real
# Google Chrome fallback (also the engine used for the Proxmox Windows CDP backend).
BROWSER_ENGINE=camoufox

# --- Browser egress (FR-STEALTH-4) ---
# direct = host's own (residential) connection; residential-proxy requires
# EGRESS_PROXY_URL (attested residential), threaded into the real browser launch.
# A datacenter exit is refused; residential-proxy mode without a proxy refuses to launch.
EGRESS_MODE=direct
EGRESS_PROXY_URL=

# --- Observability (FR-OBS-1) ---
LOG_FORMAT=pretty
LOG_LEVEL=INFO

# --- Notifications (FR-NOTIF-1; configured in setup wizard) ---
DISCORD_WEBHOOK_URL=
APPRISE_URLS=

# --- Takeover desktop + remote view (FR-SANDBOX-2/3, FR-PREFILL-5) ---
# The takeover environment is a containerized, web-streamed FULL Ubuntu desktop the
# user drives during an irreducible human step. The DE is configurable (X11, not
# Wayland): cinnamon (default) | xfce -> ready-made LinuxServer webtop images;
# gnome -> the local custom applicant/webtop-gnome:latest (heavier; no prebuilt GNOME
# webtop exists). TAKEOVER_DESKTOP_IMAGE pins an exact image (advanced override).
TAKEOVER_DESKTOP=cinnamon
TAKEOVER_DESKTOP_IMAGE=
# Host port the takeover desktop's web stream is published on (only when the stack
# is brought up with `--profile takeover`). Open http://<host>:${TAKEOVER_PORT} to
# take over. Defaults to 3001 to avoid colliding with common port-3000 services.
TAKEOVER_PORT=3001
# Swappable remote-view backend: webtop (full desktop, default) | neko (browser-only).
REMOTE_VIEW_BACKEND=webtop
# Neko remote-session server (used when REMOTE_VIEW_BACKEND=neko).
NEKO_ROOMS_URL=
NEKO_ROOMS_TOKEN=

# --- Sandbox backend (FR-SANDBOX-1, FR-STEALTH-1) ---
# local (default) = the webtop/Neko container path above. proxmox-windows = a NATIVE
# backend where the engine drives, and you take over, REAL Google Chrome inside a
# real, licensed Windows VM on a Proxmox node — so the fingerprint (JA3/TLS,
# Direct3D WebGL, Segoe UI/Calibri, OS signals) is GENUINELY Windows with ZERO
# spoofing (the strongest FR-STEALTH-1). The proxmox-windows connection/login data
# is collected in the SETUP WIZARD (zero-CLI) and the secrets are sealed in the
# credential vault — the env vars below are an optional fallback ONLY (never the
# token secret / RDP password, which must come from the wizard -> vault).
SANDBOX_BACKEND=local
# STEALTH_PERSONA: blank derives it from the backend (native for proxmox-windows,
# linux for local). linux = coherent honest spoof; native = the browser's REAL
# identity, no fingerprint override (used for the real Windows VM).
STEALTH_PERSONA=
# Proxmox / Windows connection (NON-SECRET fallback; the wizard + vault are preferred).
PROXMOX_API_URL=
PROXMOX_NODE=
PROXMOX_TOKEN_ID=
PROXMOX_TEMPLATE_VMID=0
# snapshot-revert (reuse one persistent VM, default) | linked-clone (clone per session).
PROXMOX_CLONE_MODE=snapshot-revert
PROXMOX_CDP_HOST=
PROXMOX_CDP_PORT=9222
PROXMOX_RDP_USERNAME=
# rdp (one-click rdp:// URI, default) | web-console (Guacamole/web RDP URL template).
PROXMOX_TAKEOVER_METHOD=rdp
PROXMOX_TAKEOVER_URL_TEMPLATE=

# --- Desktop assist / computer use (FR-CUA, docs/spec/computer-use.md) -------
# Optional background desktop control (click/type/scroll over the OS, complementing
# the browser path) confined to the takeover/sandbox surface. The whole chain is wired;
# the front-door toggle stays LOCKED until it is actually operable. To turn it on:
#   1) set COMPUTER_USE_BACKEND=cua below, and
#   2) bake the desktop helper into the sandbox image (INSTALL_CUA_DRIVER=1 or
#      CUA_DRIVER_URL in docker/webtop-chrome/Dockerfile).
# Until both are true the health preflight reports the helper missing and the control
# stays locked — the safe default never silently does nothing.
# noop (default) = records actions but performs NO side effects (safe/test default), and
#   is never offered as operable in the UI; cua = the real desktop driver.
COMPUTER_USE_BACKEND=noop
# Override the desktop-driver binary path (for local builds/tests). Blank = auto-detect.
CUA_DRIVER_CMD=
# Capture mode: som (screenshot with numbered targets, default) or ax (accessibility-
# tree text only, the fallback when the model has no vision).
COMPUTER_USE_MODE=som
# Approval posture for desktop actions: manual (you approve each action, the cautious
# default) or session (one approval per open takeover). Either way the assistant can
# never create accounts, clear CAPTCHAs, or submit on your behalf.
COMPUTER_USE_APPROVALS=manual
# Desktop-driver anonymous telemetry — OFF by default.
CUA_TELEMETRY=false

# --- Assistant learning & memory (FR-MIND, docs/spec/agent-intelligence.md) --
# The self-improving substrate: what the assistant remembers, the playbooks it saves
# from experience, and the periodic review that proposes updates.
# in_memory (default) = the self-contained in-process store (no extra services);
# bridge = read the front-door memory/playbooks store over the internal callback
# channel (needs APPLICANT_INTERNAL_TOKEN set; degrades to empty when that is off).
MIND_BACKEND=in_memory
# Stage the assistant's proposed memory/playbook writes for your review before they
# take effect (recommended ON). Playbook and identity edits always require approval
# regardless of these.
MEMORY_WRITE_APPROVAL=true
SKILLS_WRITE_APPROVAL=true
# Size caps that keep what the assistant remembers (and the per-run prompt) bounded:
# the environment-lessons budget and the user-preferences budget, in characters.
MEMORY_MAX_CHARS=8000
USER_MAX_CHARS=4000
# Cadence of the background review that proposes memory/playbook updates. off
# (default) disables it so the substrate ships dormant; a value like daily opts in.
CURATION_SCHEDULE=off
# Model id for the (cheaper) background review pass. Blank = reuse the main model.
CURATION_MODEL=
# Cadence of the proactive notifications, same off/daily grammar as CURATION_SCHEDULE.
# The essentials nudge defaults to daily so onboarding continues conversationally — the
# engine proactively asks (in chat) for any required-to-apply data the minimal wizard
# didn't collect (#406). The "where your campaigns stand" status update stays opt-in.
ESSENTIALS_NUDGE_SCHEDULE=daily
STATUS_UPDATE_SCHEDULE=off

# --- In-UI one-click update (FR-OOBE-4) -------------------------------------
# Absolute host path of this checkout, used by the `updater` sidecar to bind-mount
# the repo (${APPLICANT_REPO_DIR}:/repo) so the in-UI "Update" button can run
# scripts/update.sh against the host Docker. AUTO-MANAGED: install.sh writes it and
# update.sh back-fills it — you normally never set this by hand. The updater also
# mounts the Docker socket; comment the `updater` service out of the prod compose to
# opt out of in-UI updates (the button then says "updater not deployed").
APPLICANT_REPO_DIR=
# Toggle the in-UI self-update button. When false the button is hidden; operators who
# deploy via a GitOps pipeline or a pinned image should set this false so no one
# accidentally updates from inside the UI (the updater sidecar is still deployed --
# comment it out of the compose to remove it entirely). Default true (enabled).
APPLICANT_UPDATE_ENABLED=true

# --- Workspace / front-door (FR-UI, NFR-SEC-1) --------------------------------
# Mark session cookies as Secure (HTTPS-only). Set true when the front-door sits
# behind TLS (reverse proxy with X-Forwarded-Proto: https); leave false for
# localhost dev or plain-HTTP LAN deployments. Default false.
SECURE_COOKIES=false
# Maximum upload size in bytes for file uploads (resumes, fonts, attachments).
# Default 10 MB (10_485_760). Increase for very large attachments.
MAX_UPLOAD_SIZE=10485760
# Cap on concurrent sandbox/desktop sessions so automated pre-fill never starves
# the host. Default 3; raise if your host has more CPU/RAM headroom.
SANDBOX_CONCURRENCY=3
# Let the engine CREATE new ATS accounts from banked credentials when it reaches an
# account-creation gate (ADR-0004). Default false: the gate stays an irreducible
# human hand-off unless you opt in. CAPTCHA / email-SMS verification / final-submit
# remain irreducible regardless.
ALLOW_AUTOMATED_ACCOUNTS=false
