# Applicant — environment template. Copy to .env and edit. Secrets never committed.

# --- Storage (FR-CRIT-4, FR-DUR-3: DBOS state co-resides in this same Postgres) ---
DATABASE_URL=postgresql+psycopg://applicant:applicant@localhost:5432/applicant

# --- Static / frontend (FR-UI-1: vendored Odysseus + our screens served from FastAPI) ---
APP_STATIC_DIR=frontend/static

# --- LLM (FR-LLM-1/2: OpenAI-compatible cloud OR local/network Ollama; runs fully local) ---
# Until LLM_* is configured the OOBE LLM gate blocks downstream routes (FR-UI-5, FR-OOBE-1).
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# --- Credential vault master key file (FR-VAULT-3: strict-permission key-file on disk) ---
CREDENTIAL_KEYFILE=secrets/master.key

# --- Durable orchestration (FR-DUR-3). "shim" = DB/file checkpoint (default, no PG needed); "dbos" = DBOS Transact ---
ORCHESTRATOR_BACKEND=shim
CHECKPOINT_DIR=.applicant_checkpoints

# --- Observability (FR-OBS-1) ---
LOG_FORMAT=pretty
LOG_LEVEL=INFO

# --- Notifications (FR-NOTIF-1; configured in setup wizard) ---
DISCORD_WEBHOOK_URL=
APPRISE_URLS=
