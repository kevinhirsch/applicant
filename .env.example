# Applicant — environment template. Copy to .env and edit. Secrets never committed.

# --- Storage (FR-CRIT-4, FR-DUR-3: DBOS state co-resides in this same Postgres) ---
DATABASE_URL=postgresql+psycopg://applicant:applicant@localhost:5432/applicant

# --- Static / frontend (FR-UI-1: vendored Applicant + our screens served from FastAPI) ---
APP_STATIC_DIR=frontend/static

# --- LLM (FR-LLM-1/2: OpenAI-compatible cloud OR local/network Ollama; runs fully local) ---
# Until LLM_* is configured the OOBE LLM gate blocks downstream routes (FR-UI-5, FR-OOBE-1).
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# --- Credential vault master key file (FR-VAULT-3: strict-permission key-file on disk) ---
CREDENTIAL_KEYFILE=secrets/master.key

# --- Durable orchestration (FR-DUR-3). "shim" = DB/file checkpoint (default, no PG needed); "dbos" = DBOS Transact ---
ORCHESTRATOR_BACKEND=shim
CHECKPOINT_DIR=.applicant_checkpoints

# --- Scheduler (FR-DIG-1, FR-NOTIF-2, NFR-247-1). OFF by default so tests/TestClient
# never spin a live loop; set true in a real deployment to run the 24/7 cadence. ---
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=60

# --- Browser egress (FR-STEALTH-4) ---
# direct = host's own (residential) connection; residential-proxy requires
# EGRESS_PROXY_URL (attested residential), threaded into the real browser launch.
# A datacenter exit is refused; residential-proxy mode without a proxy refuses to launch.
EGRESS_MODE=direct
EGRESS_PROXY_URL=

# --- Observability (FR-OBS-1) ---
LOG_FORMAT=pretty
LOG_LEVEL=INFO

# --- Notifications (FR-NOTIF-1; configured in setup wizard) ---
DISCORD_WEBHOOK_URL=
APPRISE_URLS=

# --- Takeover desktop + remote view (FR-SANDBOX-2/3, FR-PREFILL-5) ---
# The takeover environment is a containerized, web-streamed FULL Ubuntu desktop the
# user drives during an irreducible human step. The DE is configurable (X11, not
# Wayland): cinnamon (default) | xfce -> ready-made LinuxServer webtop images;
# gnome -> the local custom applicant/webtop-gnome:latest (heavier; no prebuilt GNOME
# webtop exists). TAKEOVER_DESKTOP_IMAGE pins an exact image (advanced override).
TAKEOVER_DESKTOP=cinnamon
TAKEOVER_DESKTOP_IMAGE=
# Swappable remote-view backend: webtop (full desktop, default) | neko (browser-only).
REMOTE_VIEW_BACKEND=webtop
# Neko remote-session server (used when REMOTE_VIEW_BACKEND=neko).
NEKO_ROOMS_URL=
NEKO_ROOMS_TOKEN=

# --- Sandbox backend (FR-SANDBOX-1, FR-STEALTH-1) ---
# local (default) = the webtop/Neko container path above. proxmox-windows = a NATIVE
# backend where the engine drives, and you take over, REAL Google Chrome inside a
# real, licensed Windows VM on a Proxmox node — so the fingerprint (JA3/TLS,
# Direct3D WebGL, Segoe UI/Calibri, OS signals) is GENUINELY Windows with ZERO
# spoofing (the strongest FR-STEALTH-1). The proxmox-windows connection/login data
# is collected in the SETUP WIZARD (zero-CLI) and the secrets are sealed in the
# credential vault — the env vars below are an optional fallback ONLY (never the
# token secret / RDP password, which must come from the wizard -> vault).
SANDBOX_BACKEND=local
# STEALTH_PERSONA: blank derives it from the backend (native for proxmox-windows,
# linux for local). linux = coherent honest spoof; native = the browser's REAL
# identity, no fingerprint override (used for the real Windows VM).
STEALTH_PERSONA=
# Proxmox / Windows connection (NON-SECRET fallback; the wizard + vault are preferred).
PROXMOX_API_URL=
PROXMOX_NODE=
PROXMOX_TOKEN_ID=
PROXMOX_TEMPLATE_VMID=0
# snapshot-revert (reuse one persistent VM, default) | linked-clone (clone per session).
PROXMOX_CLONE_MODE=snapshot-revert
PROXMOX_CDP_HOST=
PROXMOX_CDP_PORT=9222
PROXMOX_RDP_USERNAME=
# rdp (one-click rdp:// URI, default) | web-console (Guacamole/web RDP URL template).
PROXMOX_TAKEOVER_METHOD=rdp
PROXMOX_TAKEOVER_URL_TEMPLATE=
