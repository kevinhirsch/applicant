# Applicant V2 shell image.
#
# Build ON the pristine published upstream Agent Zero image (D6 / D26: the vendored
# agent-zero/ subtree is byte-identical to the agent0ai/agent-zero v2.4 release, so
# the image already has a fully dependency-resolved runtime). The previous stub
# rebuilt the framework from python:3.12-slim with a naive
#   pip install -r requirements.txt -r requirements2.txt
# which hits a hard, deterministic conflict (requirements.txt vs requirements2.txt:
# openai==1.99.5 / litellm ResolutionImpossible). Building FROM the release image
# avoids re-resolving deps entirely and matches what actually runs in production.
FROM agent0ai/agent-zero:v2.4

# Engine MCP registration is injected at runtime via A0_SET_MCP_SERVERS
# (see docker/docker-compose.prod.yml, AZ0-6/#828): a0 seeds its mcp_servers default
# from that env var, pre-registering the Applicant engine's SSE /mcp surface.

# AZ0-5 build-mount: overlay the Applicant plugin bundle so the shell loads it.
# It goes in /a0/plugins (the framework's BUILT-IN plugin root — helpers/plugins.py
# get_plugin_roots() scans both usr/plugins and plugins/), NOT /a0/usr/plugins:
# the a0-data:/a0/usr named volume MASKS image content under /a0/usr on first boot,
# so a shipped plugin placed there is hidden (and would never update with a release).
# /a0/plugins is image content, unmasked, and refreshed on every image update — the
# right home for a shipped-immutable product plugin (per-user config still lives in
# the /a0/usr volume). The subtree stays byte-pristine (additive overlay, D6).
COPY a0-applicant/ /a0/plugins/applicant/
