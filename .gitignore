# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.so

# Virtualenv / uv
.venv/
.uv/

# Environment / secrets
.env
*.key
secrets/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.cache/

# Alembic scratch
alembic_tmp/

# Durable-checkpoint shim spill (local file-backed orchestrator)
.applicant_checkpoints/
*.checkpoint.json

# Confined runtime font installs (FR-FONT-2)
.applicant_fonts/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
workspace/data/
workspace/logs/
workspace/.ssh/
workspace/.cache/
workspace/.local/

# DB dumps from scripts/update.sh — never commit PII backups
.backups/

# Claude Code local state (agent worktrees, session settings) — never track
.claude/

# Ephemeral UI-audit telemetry (screenshots, node_modules, browsers)
.audit-telemetry/

# Runtime résumé/cover render output (xelatex/lualatex work dirs + PDFs)
.artifacts/
